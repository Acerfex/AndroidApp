<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Hier schalten wir das lila Banner komplett ab (NoActionBar) -->
    <style name="Theme.GithubAction" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Wir machen die Hauptfarben weiß, damit nichts Ihre Webseite stört -->
        <item name="colorPrimary">#FFFFFF</item>
        <item name="colorPrimaryVariant">#FFFFFF</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="colorSecondary">#FFFFFF</item>
        <item name="colorSecondaryVariant">#FFFFFF</item>
        <item name="colorOnSecondary">#000000</item>
        
        <!-- Statusleiste oben unsichtbar/weiß machen -->
        <item name="android:statusBarColor" tools:targetApi="l">#FFFFFF</item>
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
    </style>
</resources>
